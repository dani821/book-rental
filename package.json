{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint resources/js --fix",
        "lint:check": "eslint resources/js",
        "format": "prettier --write \"resources/js/**/*.{ts,vue}\" \"resources/css/**/*.css\"",
        "format:check": "prettier --check \"resources/js/**/*.{ts,vue}\" \"resources/css/**/*.css\"",
        "type-check": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@lucide/vue": "^1.17.0",
        "axios": "^1.16.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "pinia": "^3.0.4",
        "tailwind-merge": "^3.6.0",
        "vue": "^3.5.35",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^24.9.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/tsconfig": "^0.9.1",
        "concurrently": "^9.0.1",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.1",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.0",
        "vue-tsc": "^3.3.3"
    }
}
